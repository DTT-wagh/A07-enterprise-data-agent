# 后端环境变量样例
# 复制为 .env 后填入实际值，.env 文件不要提交到 Git

# ===== 应用 =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production

# ===== CORS（前端开发地址）=====
APP_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ===== 数据库 =====
# PostgreSQL（推荐，演示用 Docker 一键启动）
# macOS / Linux
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/a07
# Windows（请改成你的密码）
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/a07
# Docker（两平台一致）
# DATABASE_URL=postgresql://a07:a07@localhost:5432/a07

# SQLite 降级（无 PG 时使用，文件路径相对项目根）
# DATABASE_URL=sqlite:///./data/a07.db

# ===== LLM 主供应商：DeepSeek =====
LLM_API_KEY=<YOUR_DEEPSEEK_API_KEY>
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# ===== LLM 备用供应商：Qwen =====
FALLBACK_LLM_API_KEY=<YOUR_QWEN_API_KEY>
FALLBACK_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
FALLBACK_LLM_MODEL=qwen-turbo

# ===== SQL 安全 =====
SQL_MAX_ROWS=1000
SQL_TIMEOUT_SECONDS=30
